{
  "manifest_version": 3,
  "name": "HAR Reverse Engineer",
  "version": "0.3.0",
  "description": "Capture HAR from DevTools and find the API request you need",
  "devtools_page": "devtools.html",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; connect-src http://localhost:* http://127.0.0.1:*"
  }
}
