{
  "version": "1.0",
  "name": "HARBench",
  "description": "Ground truth benchmark for LLM-assisted API discovery from HAR files",
  "cases": [
    {
      "id": "simple-weather",
      "harFile": "test-fixtures/simple.har",
      "description": "the weather forecast API",
      "expectedUrlPattern": "/v3/wx/forecast",
      "expectedMethod": "GET",
      "difficulty": "easy",
      "category": "weather"
    },
    {
      "id": "simple-joke",
      "harFile": "test-fixtures/simple.har",
