            "text": "/**\n * CSS Custom Properties\n * ======================\n * Auto-generated from LESS variables in static/css/less/\n *\n * DO NOT EDIT THIS FILE DIRECTLY!\n * Run: node scripts/generate-css-custom-properties.js\n *\n */\n\n:root {\n  --border-radius-sm: 2px;\n  --border-radius-md: 4px;\n  --border-radius-lg: 8px;\n  --border-radius-xl: 16px;\n  --border-radius-xxl: 32px;\n  --border-radius-pill: 9999px;\n  --border-radius-circle: 50%;\n  --border-radius-square: 0;\n  --border-radius-button: 4px;\n  --border-radius-input: 4px;\n  --border-radius-thumbnail: 2px;\n  --border-radius-media: 8px;\n  --border-radius-card: 8px;\n  --border-radius-overlay: 16px;\n  --border-radius-badge: 2px;\n  --border-radius-notification: 8px;\n  --border-radius-avatar: 50%;\n  --border-width-none: 0;\n  --border-width-thin: 1px;\n  --border-width: 1px;\n  --border-width-thick: 2px;\n  --border-width-heavy: 3px;\n  --border-width-control: 1px;\n  --border-width-media: 1px;\n  --border-width-table: 1px;\n  --border-width-divider: 1px;\n  --focus-width: 2px;\n  --border-card: 1px solid hsl(0, 0%, 87%);\n  --border-divider: 1px solid hsl(0, 0%, 87%);\n  --border-table: 1px solid hsl(0, 0%, 87%);\n  --border-input: 1px solid hsl(0, 0%, 87%);\n  --border-input-hovered: 1px solid hsl(202, 96%, 37%);\n  --border-input-focused: 1px solid hsl(202, 96%, 37%);\n  --box-shadow-focus: 0 0 0 2px hsl(202, 96%, 37%);\n  --width-breakpoint-mobile-s: 375px;\n  --width-breakpoint-mobile-m: 425px;\n  --width-breakpoint-mobile: 450px;\n  --width-breakpoint-tablet: 768px;\n  --width-breakpoint-desktop: 960px;\n  --primary-blue: hsl(202, 96%, 37%);\n  --link-blue: hsl(202, 96%, 28%);\n  --mid-blue: hsl(204, 70%, 53%);\n  --dark-blue: hsl(210, 100%, 20%);\n  --darker-brand-blue: hsl(198, 100%, 36%);\n  --header-nav-hover-color: hsl(207, 83%, 33%);\n  --blue-b0bed9: hsl(220, 35%, 77%);\n  --count-blue-grey: hsl(211, 28%, 41%);\n  --grey-blue: hsl(211, 37%, 89%);\n  --teal: hsl(184, 100%, 21%